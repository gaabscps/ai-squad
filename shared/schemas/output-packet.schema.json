{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ai-squad/shared/schemas/output-packet.schema.json",
  "title": "ai-squad Output Packet",
  "description": "Canonical structural contract for Output Packets emitted by all Phase 4 Subagents (dev, code-reviewer, logic-reviewer, qa, blocker-specialist). Subagents self-validate against this schema before atomic write; orchestrator re-validates on read and adds semantic checks (paths exist, commit SHA resolves, status enum matches Role's allowed transitions).",
  "type": "object",
  "required": ["spec_id", "dispatch_id", "role", "status", "evidence"],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^FEAT-\\d{3,}$",
      "description": "Sequential FEAT-NNN id of the Session"
    },
    "dispatch_id": {
      "type": "string",
      "description": "Unique per-dispatch id; generated by orchestrator and round-tripped"
    },
    "role": {
      "type": "string",
      "enum": ["dev", "code-reviewer", "logic-reviewer", "qa", "blocker-specialist"],
      "description": "Subagent that produced this Packet; orchestrator verifies match against dispatch"
    },
    "status": {
      "type": "string",
      "enum": ["done", "needs_review", "blocked", "escalate"]
    },
    "blocker_kind": {
      "type": "string",
      "description": "Required when status is blocked or escalate; enum maintained loosely (contract_violation, missing_test_infra, missing_test_for_ac, timeout, etc.)"
    },
    "missing_for": {
      "type": "array",
      "items": { "type": "string" },
      "description": "qa-specific: AC ids that could not be reached when blocker_kind is missing_test_for_ac"
    },
    "summary": {
      "type": "string",
      "maxLength": 200,
      "description": "Optional one-line summary"
    },
    "notes": {
      "type": "string",
      "maxLength": 80,
      "description": "Optional one-liner if explanation outside packet fields is needed"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["file", "command", "commit", "test", "log", "url", "absence"]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor", "error", "warning", "info"]
          },
          "rationale": { "type": "string", "maxLength": 120 },
          "dimension": {
            "type": "string",
            "enum": ["design", "style", "naming", "comments", "complexity"],
            "description": "code-reviewer findings ONLY"
          },
          "gap_kind": {
            "type": "string",
            "enum": ["edge_case", "missing_flow", "partial_failure", "race", "invariant"],
            "description": "logic-reviewer findings ONLY"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "summary"],
        "additionalProperties": true,
        "properties": {
          "kind": { "type": "string" },
          "summary": { "type": "string" },
          "ac_refs": { "type": "array", "items": { "type": "string" } },
          "suggested_resolution_paths": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "dev-only: paths actually edited; orchestrator verifies subset of Work Packet's scope_files"
    },
    "ac_coverage": {
      "type": "object",
      "patternProperties": {
        "^AC-\\d{3,}$": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false,
      "description": "qa-only: AC id -> evidence ids that validate it; every AC in Work Packet's ac_scope MUST appear as a key"
    },
    "next_role": {
      "type": "string",
      "enum": ["dev", "code-reviewer", "logic-reviewer", "qa", "blocker-specialist"],
      "description": "Optional hint; orchestrator decides actual routing"
    }
  }
}
