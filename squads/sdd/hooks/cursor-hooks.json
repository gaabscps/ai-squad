{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "python3 ./hooks/ai-squad/block-git-write.py",
        "matcher": "Shell",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "python3 ./hooks/ai-squad/verify-audit-dispatch.py",
        "timeout": 5,
        "loop_limit": 5
      },
      {
        "command": "python3 ./hooks/ai-squad/register-impl-session.py",
        "timeout": 5,
        "loop_limit": 5
      },
      {
        "command": "python3 ./hooks/ai-squad/capture-session-cost.py",
        "timeout": 10,
        "loop_limit": 5
      },
      {
        "command": "python3 ./hooks/ai-squad/generate-session-report.py",
        "timeout": 20,
        "loop_limit": 5
      }
    ],
    "subagentStop": [
      {
        "command": "python3 ./hooks/ai-squad/verify-output-packet.py",
        "timeout": 5,
        "loop_limit": 5
      },
      {
        "command": "python3 ./hooks/ai-squad/capture-subagent-cost.py",
        "timeout": 10,
        "loop_limit": 5
      }
    ]
  }
}
